{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LobbyTally",
  "version": "0.1.0",
  "identifier": "dev.mpgs.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../.. --filter lobbytally-web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../../.. --filter lobbytally-web build",
    "frontendDist": "../../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "LobbyTally — 熟人联机游戏推荐",
        "width": 1280,
        "height": 800,
        "minWidth": 820,
        "minHeight": 520,
        "decorations": false,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: http:; connect-src 'self' https: http:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
