{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MPGS",
  "version": "0.1.0",
  "identifier": "dev.mpgs.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../.. --filter mpgs-web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../../.. --filter mpgs-web build",
    "frontendDist": "../../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MPGS — 熟人联机游戏推荐",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:8080 http://localhost:8080; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
