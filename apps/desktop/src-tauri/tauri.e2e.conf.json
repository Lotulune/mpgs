{
  "build": {
    "beforeBuildCommand": "pnpm --dir ../../.. --filter lobbytally-web build --mode e2e"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LobbyTally — 熟人联机游戏推荐",
        "width": 1280,
        "height": 800,
        "minWidth": 820,
        "minHeight": 520,
        "decorations": false,
        "shadow": true,
        "center": true,
        "additionalBrowserArgs": "--remote-debugging-port=0 --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --autoplay-policy=no-user-gesture-required"
      }
    ]
  }
}
