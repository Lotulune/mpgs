          "200": {
            "description": "Server configuration state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigStateResponse"
                }
              }
            }
          },
          "401": {
            "description": "Admin session required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Config manager unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
