    "/api/v1/admin/restart": {
      "post": {
        "tags": [
          "admin"
        ],
        "operationId": "admin_restart",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RestartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Managed restart scheduled through service self-exit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RestartResponse"
                }
              }
            }
          },
          "400": {
            "description": "Restart confirmation required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "401": {
            "description": "Admin session required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "409": {
            "description": "Pending config required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Config manager unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
