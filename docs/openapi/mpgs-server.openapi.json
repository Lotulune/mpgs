    },
    "/api/v1/discovery-home": {
      "get": {
        "tags": [
          "public"
        ],
        "operationId": "discovery_home",
        "parameters": [
          {
            "name": "If-None-Match",
            "in": "header",
            "description": "Return 304 when the public discovery home ETag still matches",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Public catalog discovery home summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoveryHomeResponse"
                }
              }
            }
          },
          "304": {
            "description": "Public catalog discovery home has not changed"
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Public catalog unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/games": {
      "get": {
        "tags": [
          "public"
        ],
        "operationId": "games",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "description": "Return 304 when the paginated public games ETag still matches",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated public games",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicGamesPage"
                }
              }
            }
          },
          "304": {
            "description": "Paginated public games have not changed"
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Public catalog unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/games/{appid}": {
      "get": {
        "tags": [
          "public"
        ],
        "operationId": "game_detail",
        "parameters": [
          {
            "name": "appid",
            "in": "path",
            "description": "Steam AppID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "description": "Return 304 when the public game detail ETag still matches",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Public game detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicGameDetail"
                }
              }
            }
          },
          "304": {
            "description": "Public game detail has not changed"
          },
          "404": {
            "description": "Public game not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Public catalog unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/games/{appid}/analysis": {
      "get": {
        "tags": [
          "public"
        ],
        "operationId": "game_analysis",
        "parameters": [
          {
            "name": "appid",
            "in": "path",
            "description": "Steam AppID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "description": "Return 304 when the public game analysis ETag still matches",
