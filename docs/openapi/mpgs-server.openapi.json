            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Public game analysis",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicGameAnalysis"
                }
              }
            }
          },
          "304": {
            "description": "Public game analysis has not changed"
          },
          "404": {
            "description": "Public game analysis not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Public catalog unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/service-info": {
      "get": {
        "tags": [
          "public"
        ],
        "operationId": "service_info",
        "responses": {
          "200": {
            "description": "Public MPGS service identity information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/setup/complete": {
      "post": {
        "tags": [
          "setup"
        ],
        "operationId": "setup_complete",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetupCompleteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "First-run setup wrote active configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupCompleteResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid setup token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "409": {
            "description": "Setup is already configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "Setup is unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/setup/status": {
      "get": {
        "tags": [
          "setup"
        ],
        "operationId": "setup_status",
        "responses": {
          "200": {
            "description": "First-run setup status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupStatusResponse"
                }
              }
            }
          },
          "429": {
            "description": "Request rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "Public service health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service dependency unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdminDiagnosticsResponse": {
        "type": "object",
        "required": [
          "postgres",
          "activeConfig",
          "safeMode"
        ],
        "properties": {
          "activeConfig": {
            "type": "string"
          },
          "postgres": {
            "type": "string"
          },
          "safeMode": {
            "type": "boolean"
          }
        }
      },
      "AdminOverviewResponse": {
        "type": "object",
        "required": [
          "serviceName",
          "publicCatalogStatus"
        ],
        "properties": {
          "publicCatalogStatus": {
            "$ref": "#/components/schemas/PublicCatalogStatus"
          },
          "serviceName": {
            "type": "string"
          }
        }
      },
      "AdminSessionRequest": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "AdminSessionResponse": {
        "type": "object",
        "required": [
          "authenticated"
        ],
        "properties": {
          "authenticated": {
            "type": "boolean"
          }
        }
      },
      "ConfigStateResponse": {
        "type": "object",
        "required": [
          "activeConfigVersion",
          "restartRequired",
          "lastStartupStatus"
        ],
        "properties": {
          "activeConfigVersion": {
            "type": "string"
          },
          "lastStartupStatus": {
            "type": "string"
          },
          "pendingConfigVersion": {
            "type": [
              "string",
              "null"
            ]
          },
          "restartRequired": {
            "type": "boolean"
          }
        }
      },
      "DiscoveryHomeResponse": {
        "type": "object",
        "required": [
          "status",
          "totalGames",
          "sections"
        ],
        "properties": {
          "sections": {
            "$ref": "#/components/schemas/DiscoveryHomeSections"
          },
          "status": {
            "$ref": "#/components/schemas/PublicCatalogStatus"
          },
          "totalGames": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "DiscoveryHomeSections": {
        "type": "object",
        "required": [
          "newlyPublished",
          "highConfidence",
          "recentlyAdded"
        ],
        "properties": {
          "highConfidence": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicGameListItem"
            }
          },
          "newlyPublished": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicGameListItem"
            }
          },
          "recentlyAdded": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicGameListItem"
            }
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          }
        }
      },
      "HealthStatus": {
        "type": "string",
        "enum": [
          "ok",
          "unavailable"
        ]
      },
      "PageMeta": {
        "type": "object",
        "required": [
          "limit",
          "offset",
          "total"
        ],
        "properties": {
          "limit": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "offset": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "PendingConfigResponse": {
        "type": "object",
        "required": [
          "pendingConfigVersion",
          "restartRequired"
        ],
        "properties": {
          "pendingConfigVersion": {
            "type": "string"
          },
          "restartRequired": {
            "type": "boolean"
          }
        }
      },
      "PendingServiceIdentityRequest": {
        "type": "object",
        "required": [
          "serviceName"
        ],
        "properties": {
          "serviceName": {
            "type": "string"
          }
        }
      },
      "PublicCatalogStatus": {
        "type": "string",
        "enum": [
          "empty",
          "ready",
          "updating",
          "unavailable"
        ]
      },
      "PublicGameAnalysis": {
        "type": "object",
        "required": [
          "appid",
          "report",
          "generatedAt"
        ],
        "properties": {
          "appid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "generatedAt": {
            "type": "string"
          },
          "report": {}
        }
      },
      "PublicGameDetail": {
        "type": "object",
        "required": [
          "game"
        ],
        "properties": {
          "game": {
            "$ref": "#/components/schemas/PublicGameListItem"
          }
        }
      },
      "PublicGameListItem": {
        "type": "object",
        "required": [
          "appid",
          "name",
          "updatedAt"
        ],
        "properties": {
          "appid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "name": {
            "type": "string"
          },
          "recommendationScore": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "PublicGamesPage": {
        "type": "object",
        "required": [
          "items",
          "page"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicGameListItem"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageMeta"
          }
        }
      },
      "RestartRequest": {
        "type": "object",
        "required": [
          "confirm"
        ],
        "properties": {
          "confirm": {
