# Copy to deploy/mpgs.env on the VPS. Do not commit the real file.
MPGS_ADMIN_TOKEN=
MPGS_RATE_LIMIT_ENABLED=true
MPGS_TRUST_PROXY_HEADERS=true
MPGS_CORS_ENABLED=true
MPGS_CORS_ALLOWED_ORIGINS=https://mpgs.lunafleur.dpdns.org
MPGS_WORKER_INTERVAL_SECS=60
MPGS_WORKER_JOB_LIMIT=10
MPGS_WORKER_ENRICH_LIMIT=100
# Optional: enables the official Steam catalog sync job.
# MPGS_STEAM_WEB_API_KEY=
