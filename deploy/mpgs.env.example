# Copy to deploy/mpgs.env on the VPS. Do not commit the real file.
MPGS_ADMIN_TOKEN=
MPGS_RATE_LIMIT_ENABLED=true
MPGS_TRUST_PROXY_HEADERS=true
MPGS_CORS_ENABLED=true
MPGS_CORS_ALLOWED_ORIGINS=https://mpgs.lunafleur.dpdns.org
MPGS_WORKER_INTERVAL_SECS=60
MPGS_WORKER_JOB_LIMIT=10
MPGS_WORKER_ENRICH_LIMIT=100
# Optional: enables the official Steam catalog sync job.
# MPGS_STEAM_WEB_API_KEY=

# Built-in OpenAI-compatible AI gateway (M8 multi-model routing).
# Keep the real key only in deploy/mpgs.env on the server — never in Git or images.
# MPGS_AI_PROVIDER=disabled
# MPGS_AI_BASE_URL=https://example.com/v1
# MPGS_AI_API_KEY=
# Multi-model is ON by default. Set MPGS_AI_MULTI_MODEL=false to collapse
# every online task onto a single MPGS_AI_MODEL (legacy M5 behaviour).
# MPGS_AI_MULTI_MODEL=true
# Provider default / single-model mode only:
# MPGS_AI_MODEL=grok-4.5
# MPGS_AI_TIMEOUT_SECS=45
# Task route overrides (optional; defaults use grok-4.5 primary).
# IntentParse default timeout is 12s (shared across the full model/protocol chain).
# Raise if cold Responses latency is high in your region:
# MPGS_AI_ROUTE_INTENT_PARSE_MODEL=grok-4.5
# MPGS_AI_ROUTE_INTENT_PARSE_FALLBACKS=grok-4.20-0309-non-reasoning,grok-4.3
# MPGS_AI_ROUTE_INTENT_PARSE_TIMEOUT_SECS=15
# MPGS_AI_ROUTE_RANK_EXPLAIN_MODEL=grok-4.5
# MPGS_AI_ROUTE_RANK_EXPLAIN_FALLBACKS=grok-4.20-0309-non-reasoning,grok-4.3
# Embedding: Grok2API has no usable embedding models for MPGS — keep hash.
# MPGS_AI_EMBED_PROVIDER=hash
# MPGS_AI_EMBED_DIMENSIONS=64
